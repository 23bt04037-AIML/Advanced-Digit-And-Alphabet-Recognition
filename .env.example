# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=mysql+mysqlconnector://root:password@localhost:3306/digit_recognition
DB_HOST=localhost
DB_PORT=3306
DB_NAME=digit_recognition
DB_USER=root
DB_PASSWORD=password

# ── Application ───────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=change-me-in-production-use-32-random-chars

# ── Model ─────────────────────────────────────────────────────────
DEFAULT_MODEL=cnn_medium
MODELS_DIR=models

# ── File Storage ──────────────────────────────────────────────────
UPLOAD_DIR=frontend/static/uploads
HEATMAPS_DIR=frontend/static/heatmaps
MAX_UPLOAD_SIZE_MB=10
